# Microsoft Fabric
FABRIC_WORKSPACE_ID=your_workspace_id_here
FABRIC_LAKEHOUSE_ID=your_lakehouse_id_here
ONELAKE_ENDPOINT=https://onelake.dfs.fabric.microsoft.com

# Azure
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here

# Kafka / Event Hub
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ORDERS=retail-orders
KAFKA_TOPIC_INVENTORY=retail-inventory
EVENT_HUB_CONNECTION_STRING=your_event_hub_connection_here

# External APIs
OPENWEATHER_API_KEY=your_key_here

# Database
SQL_SERVER_CONNECTION=your_connection_string_here

# Environment
ENVIRONMENT=dev
LOG_LEVEL=INFO
