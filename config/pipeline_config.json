      "target_layer": "bronze",
      "target_table": "bronze_customers_cdc",
      "partition_columns": ["ingestion_date"],
      "primary_key": "customer_id",
      "dq_rules_id": "DQ-003",
      "schedule": "every_15min",
      "is_active": true,
      "tags": ["customers", "cdc", "incremental"]
    },
    {
      "pipeline_id": "PL-006",
