      "dq_rules_id": "DQ-002",
      "schedule": "daily_7am",
      "is_active": true,
      "tags": ["inventory", "warehouse"]
    },
    {
      "pipeline_id": "PL-004",
      "pipeline_name": "customers_full_load",
      "source_name": "crm_database",
