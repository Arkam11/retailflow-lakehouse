      "file_format": "json",
      "load_type": "incremental",
      "watermark_column": "order_date",
      "target_layer": "bronze",
      "target_table": "bronze_sales_incremental",
      "partition_columns": ["ingestion_date"],
      "primary_key": "order_id",
      "dq_rules_id": "DQ-001",
      "schedule": "hourly",
      "is_active": true,
      "tags": ["sales", "orders", "incremental"]
    },
    {
