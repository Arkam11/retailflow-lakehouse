      "target_table": "bronze_sales_orders",
      "partition_columns": ["ingestion_date", "region"],
      "primary_key": "order_id",
      "dq_rules_id": "DQ-001",
      "schedule": "daily_6am",
      "is_active": true,
      "tags": ["sales", "orders", "ecommerce"]
    },
    {
      "pipeline_id": "PL-002",
      "pipeline_name": "sales_orders_incremental",
      "source_name": "ecommerce_oms",
